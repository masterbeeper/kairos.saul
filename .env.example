# .env.example
# ──────────────────────────────────────────────────────────────
# Copy this to .env and fill in your values.
# NEVER commit .env to GitHub — it is gitignored.
#
# TIGER PRIVATE KEY → stored in macOS Keychain (NOT in this file)
# Run the one-time setup command below, then never touch it again.
# ──────────────────────────────────────────────────────────────

# ── Tiger Private Key — One-time Keychain setup ───────────────
#
# Run this once in Terminal (from the folder with your Tiger config file):
#
#   python3 -c "
#   import base64, subprocess
#   with open('tiger_openapi_config.properties') as f:
#       for line in f:
#           if 'private_key_pk1' in line:
#               raw = line.split('=',1)[1].strip(); break
#   p = 4 - len(raw) % 4
#   if p != 4: raw += '=' * p
#   base64.b64decode(raw)
#   subprocess.run(['security','add-generic-password',
#       '-a','tiger_quant','-s','tiger_private_key','-w',raw,'-U'])
#   print('Key stored in Keychain')
#   "
#
# Verify: security find-generic-password -a "tiger_quant" -s "tiger_private_key" -w | head -c 20
#
# sync.py reads the key from Keychain automatically.
# Do NOT put TIGER_PRIVATE_KEY in this file.
# ──────────────────────────────────────────────────────────────

# ── Tiger (non-secret config only) ───────────────────────────
TIGER_ID=your_tiger_id
TIGER_ACCOUNT=your_account_number
TIGER_LICENSE=TBSG
TIGER_ENV=PROD

# ── Webull (uncomment when ready) ────────────────────────────
# WEBULL_USERNAME=
# WEBULL_PASSWORD=
# WEBULL_DEVICE_ID=
# WEBULL_TRADE_PIN=

# ── MooMoo (uncomment when ready) ────────────────────────────
# MOOMOO_HOST=127.0.0.1
# MOOMOO_PORT=11111
# MOOMOO_ACCOUNT_ID=
# MOOMOO_PWD_MD5=
# MOOMOO_ENV=REAL
