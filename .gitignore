# Kairos .gitignore

# Secrets — NEVER commit these
.env
*.pem
*.key
*service_account*.json

# Python
__pycache__/
*.pyc
*.pyo
.Python
venv/
.venv/
*.egg-info/

# macOS
.DS_Store
.AppleDouble

# Logs
logs/
*.log

# Editor
.vscode/
.idea/
*.swp

